{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Codex: Validate config exists",
      "type": "shell",
      "command": "Test-Path \"$env:USERPROFILE\\.codex\\config.toml\"",
      "options": { "shell": { "executable": "pwsh.exe", "args": ["-NoLogo", "-NoProfile", "-Command"] } },
      "problemMatcher": []
    },
    {
      "label": "Codex: Install configuration",
      "type": "shell",
      "command": "& \"${workspaceFolder}\\powershell\\install.ps1\"",
      "options": { "shell": { "executable": "pwsh.exe", "args": ["-NoLogo", "-NoProfile", "-Command"] } },
      "problemMatcher": []
    },
    {
      "label": "Codex: Backup configuration",
      "type": "shell",
      "command": "& \"${workspaceFolder}\\powershell\\backup.ps1\"",
      "options": { "shell": { "executable": "pwsh.exe", "args": ["-NoLogo", "-NoProfile", "-Command"] } },
      "problemMatcher": []
    },
    {
      "label": "Repository: Check Git status",
      "type": "shell",
      "command": "git status --short --branch",
      "problemMatcher": []
    }
  ]
}
